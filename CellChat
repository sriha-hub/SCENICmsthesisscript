###############################
#   DEFINE CELLCHAT FUNCTION
###############################
run_cellchat <- function(seu_obj, project_name) {
  cat("  - Extracting data...\n")
  data.input <- GetAssayData(seu_obj, assay = "RNA", slot = "data")
  meta <- seu_obj@meta.data
  
  cat("  - Creating CellChat object...\n")
  cellchat <- createCellChat(object = data.input, meta = meta, group.by = "celltype")
  
  # Set database (must be done before analysis)
  cellchat@DB <- CellChatDB.use
  
  cat("  - Preprocessing...\n")
  cellchat <- subsetData(cellchat)
  cellchat <- identifyOverExpressedGenes(cellchat, thresh.pc = 0.01, thresh.fc = 0.1)
  cellchat <- identifyOverExpressedInteractions(cellchat)
  
  cat("  - Computing communication probabilities...\n")
  cellchat <- computeCommunProb(cellchat)
  cellchat <- filterCommunication(cellchat, min.cells = 3)
  
  cat("  - Computing pathways...\n")
  cellchat <- computeCommunProbPathway(cellchat)
  cellchat <- aggregateNet(cellchat)
  
  cellchat@options$project.name <- project_name
  
  return(cellchat)
}
