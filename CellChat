# 1. Calculate Stromal→Hema Pathway Changes
calculate_stromal_hema_pathways <- function(cellchat_obj, sources, targets) {
  prob_matrix <- cellchat_obj@net$prob ## 3D array: [source x target x pathway]
  stromal_hema_prob <- prob_matrix[sources, targets, , drop = FALSE]
  pathway_strength <- apply(stromal_hema_prob, 3, sum, na.rm = TRUE) # Sum across all cell pairs
  return(data.frame(Pathway = names(pathway_strength), Strength = pathway_strength)) #Column 1 = Pathway names; #Column 2 = Their strengths
}

